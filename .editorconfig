root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{xml,plist,gradle,json}]
indent_size = 2

[{CMakeLists.txt,*.cmake,*.sh}]
indent_size = 2

[*.bat]
indent_size = 2
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false
